# Iljari 환경 — SSOT (사용자·테스트·실서비스 모두 iljari.app 도메인만)
#
# server = NCP  ·  local = 맥 hot reload

ILJARI_ENV="${ILJARI_ENV:-server}"

# ── iljari.app (유일한 공개 주소) ──
ILJARI_WEB_URL="https://iljari.app"
ILJARI_API_URL="https://api.iljari.app"

# ── 로컬 개발 (맥만) ──
ILJARI_LOCAL_API_URL="http://127.0.0.1:8000"
ILJARI_LOCAL_WEB_PORT="8082"

# ── SSH / 배포 (인프라 — 사용자에게 노출 안 함) ──
ILJARI_SSH_HOST="211.188.56.77"
ILJARI_SSH_USER="root"
ILJARI_SSH_KEY="${HOME}/Projects Keys/iljari app/iljari-key.pem"
ILJARI_SERVER_DIR_REMOTE="/opt/iljari/server"
ILJARI_REMOTE_WEB_DIR="/opt/iljari/web"
ILJARI_ADMIN_API_KEY="iljari-admin-dev-key"
ILJARI_SSL_EMAIL="${ILJARI_SSL_EMAIL:-admin@iljari.app}"

ILJARI_API_MODE="${ILJARI_ENV}"
ILJARI_REMOTE_API_URL="${ILJARI_API_URL}"
ILJARI_REMOTE_WEB_URL="${ILJARI_WEB_URL}"
ILJARI_ROOT_DOMAIN="iljari.app"
