# 공공데이터포털 / odcloud 사업자등록 상태조회 API 키 (없으면 mock)
NTS_API_KEY=
NTS_API_URL=https://api.odcloud.kr/api/nts-businessman/v1/status

# 토스페이먼츠 시크릿 키 (test_sk_ / live_sk_) — 없으면 mock 결제
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# CLOVA OCR (서버 프록시 — Flutter는 서버 URL만 알면 됨)
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=

CORS_ORIGINS=*

# ── 건강보험 자격득실 (1순위 CODEF / Hyphen) ──
CODEF_PUBLIC_KEY=
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=
HYPHEN_API_KEY=

# ── 간편인증 (2순위 Barocert / PortOne) ──
BAROCERT_LINK_ID=
BAROCERT_SECRET_KEY=
PORTONE_API_SECRET=

# CI 암호화 시크릿 (서버 전용, 주민번호 등 원문 미저장)
INSURANCE_CI_SECRET=

CODEF_API_URL=https://development.codef.io
HYPHEN_API_URL=
BAROCERT_API_URL=https://api.barocert.com
BAROCERT_ALLOW_MOCK_FALLBACK=true
PORTONE_API_URL=https://api.portone.io
PORTONE_CHANNEL_KEY=
PORTONE_ALLOW_MOCK_FALLBACK=true
APP_DEEP_LINK_SCHEME=iljari

# 30일 재직 확인 배치 (6시간마다)
REVERIFY_BATCH_ENABLED=true
REVERIFY_BATCH_INTERVAL_HOURS=6
SIMPLE_AUTH_CALLBACK_URL=http://127.0.0.1:8000/v1/insurance-auth/callback

# ── 도로명주소 검색 (행정안전부 Juso + Kakao 좌표) ──
# Juso: https://business.juso.go.kr 승인키 발급
JUSO_CONFM_KEY=
# Kakao Developers REST API 키 (주소→좌표, Juso 미설정 시 키워드 검색 fallback)
KAKAO_REST_API_KEY=
