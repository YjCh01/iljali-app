# Iljari Compliance API — copy to .env and fill in values

# QC·Admin Ops
ADMIN_API_KEY=iljari-admin-dev-key
QC_PAYMENT_MODE=wallet_only

# Auth / SMS (staging: mock code 123456)
AUTH_TOKEN_SECRET=
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_MOCK_CODE=123456
# Aligo: SMS_PROVIDER=aligo, SMS_ALIGO_USER_ID=, SMS_SENDER_ID=16445701 (발신번호 1644-5701, 하이픈 없이)
SMS_ALIGO_USER_ID=
SMS_SENDER_ID=
REQUIRE_NTS_API_KEY=false
REQUIRE_CLOVA_OCR=false

DATABASE_URL=sqlite:///./iljari_compliance.db
# DATABASE_URL=postgresql+psycopg2://iljari:iljari@db:5432/iljari

CORS_ORIGINS=http://localhost:8080,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081

# 웹 결제 리다이렉트 (구인자 웹 QC 기본값 — staging은 server/staging/env.example 참고)
PAYMENT_WEB_SUCCESS_URL=http://127.0.0.1:8081/payment-success
PAYMENT_WEB_FAIL_URL=http://127.0.0.1:8081/payment-fail

# 국세청 사업자 검증 (공공데이터포털 odcloud)
NTS_API_KEY=

# 토스페이먼츠 — test_sk_ / live_sk_ (서버 전용), test_ck_ / live_ck_ (checkout)
TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=
TOSS_WEBHOOK_SECRET=

# CLOVA OCR (선택)
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=

# 건강보험 자격득실 — CODEF / Hyphen
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=
CODEF_PUBLIC_KEY=
HYPHEN_API_KEY=

# 간편인증 — Barocert / PortOne
BAROCERT_LINK_ID=
BAROCERT_SECRET_KEY=
PORTONE_API_SECRET=
PORTONE_CHANNEL_KEY=
SIMPLE_AUTH_CALLBACK_URL=

# CI 암호화 (32자 이상)
INSURANCE_CI_SECRET=

# 주소 검색·지도 좌표 (developers.kakao.com → 앱 → 앱 키 → REST API 키)
# · KAKAO_REST_API_KEY: 도로명→좌표(지오코딩). Juso 검색 결과에 위도·경도 붙일 때 사용
# · 카카오 로그인과 동일한 REST API 키를 쓰는 경우가 많음 (Native/JS 키 아님)
# · 서버 등록: 도구_Kakao주소키_서버등록.command
KAKAO_REST_API_KEY=

# 행정안전부 도로명주소 검색 API (business.juso.go.kr → 검색 API 승인키)
# 팝업 API 키와 검색 API 키는 다릅니다. 일자리 서버는 검색 API를 사용합니다.
JUSO_CONFM_KEY=

# ── 소셜 로그인 (카카오·네이버·구글) ─────────────────────────────────────
# 키가 하나라도 있으면 mock 끔 → 없는 provider 버튼은 실패할 수 있음.
# 운영 서버(NCP): /opt/iljari/server/.env 에 아래 추가 후
#   docker compose up -d --build api
#
# 카카오 콘솔 (developers.kakao.com → 앱 일자리)
#   · 카카오 로그인 → 활성화 ON
#   · 플랫폼 키 → REST API 키 → Redirect URI:
#       https://api.iljari.app/v1/auth/social/kakao/callback
#   · Client Secret → 사용 ON
#   · KAKAO_OAUTH_CLIENT_ID     = REST API 키 (32자 전체 — 잘리면 KOE101)
#   · KAKAO_OAUTH_CLIENT_SECRET = Client Secret 코드 (앞뒤 공백 없이)
#
# 로그인 후 앱으로 돌아올 주소 (웹 iljari.app)
API_PUBLIC_BASE_URL=https://api.iljari.app
SOCIAL_APP_SUCCESS_URL=https://iljari.app/auth/social-complete
#
# 카카오 (필수 — 먼저 이것만 넣어도 카카오 로그인 실연동)
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
#
# 네이버 (콘솔 Callback: https://api.iljari.app/v1/auth/social/naver/callback)
# NAVER_OAUTH_CLIENT_ID=
# NAVER_OAUTH_CLIENT_SECRET=
#
# Google (리디렉션 URI: https://api.iljari.app/v1/auth/social/google/callback)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
#
# 강제 mock (운영에서는 보통 false / 줄 자체를 지우면 false)
# SOCIAL_AUTH_MOCK=false

# 외부 공고 스크래핑
JOB_SCRAPE_TIMEOUT_SEC=15
JOB_SCRAPE_MIN_INTERVAL_SEC=1
JOB_SCRAPE_BLOCKLIST=localhost,127.0.0.1
