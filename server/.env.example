# Iljari Compliance API — copy to .env and fill in values

# QC·Admin Ops
ADMIN_API_KEY=qc-admin-dev-key
QC_PAYMENT_MODE=wallet_only

DATABASE_URL=sqlite:///./iljari_compliance.db
# DATABASE_URL=postgresql+psycopg2://iljari:iljari@db:5432/iljari

CORS_ORIGINS=*

# 국세청 사업자 검증 (공공데이터포털 odcloud)
NTS_API_KEY=

# 토스페이먼츠 — test_sk_ / live_sk_ (서버 전용), test_ck_ / live_ck_ (checkout)
TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=
TOSS_WEBHOOK_SECRET=

# CLOVA OCR (선택)
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=

# 건강보험 자격득실 — CODEF / Hyphen
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=
CODEF_PUBLIC_KEY=
HYPHEN_API_KEY=

# 간편인증 — Barocert / PortOne
BAROCERT_LINK_ID=
BAROCERT_SECRET_KEY=
PORTONE_API_SECRET=
PORTONE_CHANNEL_KEY=
SIMPLE_AUTH_CALLBACK_URL=

# CI 암호화 (32자 이상)
INSURANCE_CI_SECRET=

# 주소 검색
JUSO_CONFM_KEY=
KAKAO_REST_API_KEY=

# 외부 공고 스크래핑
JOB_SCRAPE_TIMEOUT_SEC=15
JOB_SCRAPE_MIN_INTERVAL_SEC=1
JOB_SCRAPE_BLOCKLIST=localhost,127.0.0.1
