# Staging stack — copy to server/.env.staging and fill secrets.
# Hostnames (also used by nginx + Flutter build):
STAGING_APP_HOST=app.staging.iljari.local
STAGING_API_HOST=api.staging.iljari.local

# --- API (read by FastAPI inside docker) ---
DATABASE_URL=postgresql+psycopg2://iljari:iljari@db:5432/iljari

CORS_ORIGINS=https://app.staging.iljari.local

PAYMENT_WEB_SUCCESS_URL=https://app.staging.iljari.local/payment-success
PAYMENT_WEB_FAIL_URL=https://app.staging.iljari.local/payment-fail
SIMPLE_AUTH_CALLBACK_URL=https://api.staging.iljari.local/v1/insurance-auth/callback

AUTH_TOKEN_SECRET=replace-with-32-char-random-staging-secret
ADMIN_API_KEY=replace-staging-admin-key
REQUIRE_NTS_API_KEY=true
REQUIRE_CLOVA_OCR=true
SMS_PROVIDER=mock
SMS_MOCK_CODE=123456
QC_PAYMENT_MODE=wallet_only

# Toss sandbox (developer center — test keys)
TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=
TOSS_WEBHOOK_SECRET=

NTS_API_KEY=

# Real SMS (Aligo — smartsms.aligo.in/admin/api/auth.html)
# SMS_PROVIDER=aligo
# SMS_API_KEY=
# SMS_ALIGO_USER_ID=
# SMS_SENDER_ID=16445701
# 발송 서버 IP 등록 필수: NCP 공인 IP 211.188.56.77 (미등록 시 "인증오류입니다.-IP")

# Social OAuth — 키 미설정 시 mock(가짜 로그인). 운영은 /opt/iljari/server/.env
#
# [카카오] developers.kakao.com → 앱 일자리
#   Redirect URI: https://api.iljari.app/v1/auth/social/kakao/callback
#   Client Secret ON → REST API 키 + 시크릿 아래에 입력
API_PUBLIC_BASE_URL=https://api.iljari.app
SOCIAL_APP_SUCCESS_URL=https://iljari.app/auth/social-complete
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
# [네이버] developers.naver.com → 애플리케이션 등록
#   서비스 URL: https://iljari.app
#   Callback URL: https://api.iljari.app/v1/auth/social/naver/callback
#   제공 정보: 회원이름, 이메일, 별명(선택)
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
# [Google] console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
#   OAuth 동의 화면: 외부 · 앱 이름 일자리
#   OAuth 클라이언트: 웹 애플리케이션
#   승인된 리디렉션 URI: https://api.iljari.app/v1/auth/social/google/callback
#   테스트 단계에서는 테스트 사용자에 본인 Gmail 추가
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
