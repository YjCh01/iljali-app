NAVER_MAP_CLIENT_ID=
COMPLIANCE_API_URL=http://10.0.2.2:8000
TOSS_CLIENT_KEY=
CLOVA_OCR_URL=
CLOVA_OCR_SECRET=
NTS_API_KEY=

KAKAO_REST_API_KEY=

