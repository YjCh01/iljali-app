# Flutter build-time defines (--dart-define=KEY=value)
# Android/iOS: Mobile Dynamic Map · Web: Web Dynamic Map (동일 또는 별도 Client ID)

NAVER_MAP_CLIENT_ID=
# Web: NCP 콘솔 Web Dynamic Map + localhost/운영 도메인 등록 후
#   flutter run -d chrome --dart-define=NAVER_MAP_CLIENT_ID=YOUR_WEB_CLIENT_ID
# Windows MVP: NAVER_MAP 미설정 시 mock 지도
COMPLIANCE_API_URL=http://10.0.2.2:8000
TOSS_CLIENT_KEY=
CLOVA_OCR_URL=
CLOVA_OCR_SECRET=
NTS_API_KEY=
# 또는 DATA_GO_KR_SERVICE_KEY= (공공데이터포털 국세청 사업자 진위확인 API)
# server/.env: NTS_API_KEY= (서버 경유 권장 — Flutter에 키 노출 방지)

KAKAO_REST_API_KEY=

# 건강보험 인증(CODEF/Hyphen/Barocert/PortOne/INSURANCE_CI_SECRET)은
# Flutter가 아닌 server/.env 에 설정 — COMPLIANCE_API_URL 로 API 연동

# --- MVP 제품 범위 (product_feature_flags.dart · docs/disabled_features.md) ---
# 기본값: 일용직만 · 상시직/일반/계약 off · 제휴사 위저드 on
# ENABLE_WORKER_GENERAL=false
# ENABLE_WORKER_CONTRACT=false
# ENABLE_PERMANENT_HIRE=false
# ENABLE_PREMIUM_PARTNER_WIZARD=true
# ENABLE_ENTERPRISE_OUTSOURCING=true
